# get-livekit-token — local development environment variables
#
# Copy this file to .env.local and fill in real values for local Supabase
# function development / testing.  .env.local is gitignored.
#
# These three variables must also be set as Supabase project secrets for the
# deployed (production / staging) function.  Use the deploy script:
#
#   LIVEKIT_API_KEY=YOUR_API_KEY_HERE \
#   LIVEKIT_API_SECRET=YOUR_API_SECRET_HERE \
#   LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud \
#   ./apps/mobile/scripts/deploy-livekit-edge-function.sh
#
# Or set them manually via the Supabase CLI:
#   supabase secrets set LIVEKIT_API_KEY=YOUR_API_KEY_HERE \
#                        LIVEKIT_API_SECRET=YOUR_API_SECRET_HERE \
#                        LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud \
#                        --project-ref YOUR_PROJECT_REF
#
# Or via the Supabase Dashboard:
#   Project Settings → Edge Functions → Secrets

# LiveKit Cloud credentials (from https://cloud.livekit.io → your project → API Keys)
LIVEKIT_API_KEY=YOUR_API_KEY_HERE
LIVEKIT_API_SECRET=YOUR_API_SECRET_HERE

# LiveKit WebSocket URL (from https://cloud.livekit.io → your project → Settings)
# Format: wss://YOUR_PROJECT_NAME.livekit.cloud
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud

# Supabase vars are auto-injected in deployed functions; needed locally only
# if running `supabase functions serve` against a local Supabase instance.
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=your_local_anon_key
