# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Sign-In (Required for Google OAuth)
# Found in: Google Cloud Console → Credentials → OAuth 2.0 Client IDs → Web client
EXPO_PUBLIC_GOOGLE_AUTH_WEB_CLIENT_ID=your_google_web_client_id_here

# Apple Sign-In (Required for Apple OAuth)
# EXPO_PUBLIC_APPLE_AUTH_SERVICE_ID=your_apple_service_id_here
# EXPO_PUBLIC_APPLE_AUTH_REDIRECT_URI=big2mobile://apple-auth

# Firebase Analytics (Measurement Protocol v2)
# MEASUREMENT_ID and API_SECRET: Firebase Console → Analytics → Data Streams → Web Stream → Measurement Protocol API secrets
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
EXPO_PUBLIC_FIREBASE_API_SECRET=your_api_secret_here

# Firebase App IDs — NOT currently consumed by analytics.ts.
# firebase_app_id is intentionally omitted from GA4 Measurement Protocol
# payloads to avoid VALUE_INVALID errors with a web-stream measurement ID.
# Kept here for reference if native SDK integration is added in the future.
# EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID=1:PROJECT_NUMBER:android:APP_HASH
# EXPO_PUBLIC_FIREBASE_APP_ID_IOS=1:PROJECT_NUMBER:ios:APP_HASH

# Sentry Error Monitoring
# DSN: Sentry Dashboard → Project Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://your_key@oXXXXX.ingest.sentry.io/YYYYYYY

# App Version (injected at build time by EAS — override locally for testing)
EXPO_PUBLIC_APP_VERSION=1.0.0

