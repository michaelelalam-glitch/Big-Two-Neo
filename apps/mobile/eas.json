{
  "cli": {
    "version": ">= 13.2.3"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.0",
      "pnpm": "10.19.0",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "developmentDevice": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.0",
      "pnpm": "10.19.0",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.0",
      "pnpm": "10.19.0",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "node": "20.19.0",
      "pnpm": "10.19.0",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "test": {
      "distribution": "internal",
      "node": "20.19.0",
      "pnpm": "10.19.0",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {}
  }
