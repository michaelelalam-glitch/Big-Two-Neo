{
  "expo": {
    "name": "Big2 Mobile",
    "slug": "big2-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "scheme": "big2mobile",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9655e19-679f-4683-924a-581c54736a73",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#25292e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.big2mobile.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Big Two uses your camera for the opt-in in-game video chat feature.",
        "NSMicrophoneUsageDescription": "Big Two uses your microphone for the opt-in in-game video + audio chat feature.",
        "NSPhotoLibraryUsageDescription": "Big Two needs access to your photo library to attach screenshots to bug reports.",
        "NSAppTransportSecurity": {
          "NSPinnedDomains": {
            "supabase.co": {
              "NSIncludeSubdomains": true,
              "NSPinnedLeafIdentities": [
                {
                  "SPKI-SHA256-BASE64": "GU2W4j1P24T3sqlI+o6YTnidzz0PI8fB/Gvd2ITfSZE="
                }
              ],
              "NSPinnedCAIdentities": [
                {
                  "SPKI-SHA256-BASE64": "kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4="
                }
              ]
            }
          }
        }
      }
    },
    "android": {
      "package": "com.big2mobile.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#25292e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "@sentry/react-native/expo",
        {
          "organization": "bigtwoapp",
          "project": "big2-mobile",
          "uploadNativeSymbols": true,
          "autoUploadNativeSymbols": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B6B",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Big2 to attach screenshots to bug reports."
        }
      ],
      "expo-screen-orientation",
      "./plugins/withAndroidSupportExclude",
      "./plugins/withAndroidCertPinning",
      "./plugins/withBarcodeCompatStubs",
      "./plugins/withIOSBarcodeCompatStubs",
      "./plugins/withExpoCameraSwiftFix",
      "./plugins/withSuppressDeprecatedWarnings",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "e9655e19-679f-4683-924a-581c54736a73"
      }
    }
  }
}
