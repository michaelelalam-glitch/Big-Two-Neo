{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx expo start --no-interactive",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "ios:device": "npx expo run:ios --device",
    "web": "npx expo start --web",
    "prebuild": "npx expo prebuild --clean",
    "rebuild:native": "./scripts/rebuild-native.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "// Integration tests must run sequentially (--runInBand) to avoid race conditions in shared test database": "",
    "test:integration": "jest --testMatch='**/__tests__/integration/**/*.test.ts' --runInBand --forceExit",
    "test:unit": "jest --testPathIgnorePatterns='/integration/' --forceExit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "bundle:visualize": "npx react-native-bundle-visualizer",
    "bundle:analyze": "npx react-native-bundle-visualizer --format=json > bundle-analysis.json && echo 'Bundle analysis saved to bundle-analysis.json'",
    "bundle:report": "echo '📦 Generating bundle size report...' && npx react-native-bundle-visualizer",
    "bundle:size-check": "node scripts/check-bundle-size.js",
    "bundle:size-check:verbose": "node scripts/check-bundle-size.js --verbose"
  },
  "dependencies": {
    "@livekit/react-native": "^2.10.0",
    "@livekit/react-native-webrtc": "^137.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "@sentry/react-native": "8.7.0",
    "@shopify/flash-list": "^2.3.1",
    "@supabase/supabase-js": "^2.103.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.29",
    "expo-application": "^7.0.8",
    "expo-audio": "^1.1.1",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "~15.0.16",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "^6.0.20",
    "expo-device": "^8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "^0.32.14",
    "expo-screen-orientation": "^9.0.8",
    "expo-secure-store": "^15.0.8",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "livekit-client": "^2.18.1",
    "react": "19.2.5",
    "react-native": "0.85.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-logs": "^5.6.0",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/config-plugins": "^54.0.4",
    "@jest/globals": "~29.7.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-preset-expo": "^54.0.8",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "react-native-bundle-visualizer": "^3.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "expo-camera",
        "expo-barcode-scanner",
        "expo",
        "expo-constants",
        "expo-notifications",
        "babel-preset-expo",
        "@expo/config-plugins"
      ]
    }
  }
}
