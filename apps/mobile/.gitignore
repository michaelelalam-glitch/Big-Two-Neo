.jest-cache/

# E2E test results (generated by Maestro in CI)
e2e/results/

# backup files
*.bak
*.backup

# platform config (contains API keys)
# NOTE: google-services.json is intentionally committed — it is embedded in every
# Android APK and its Firebase API key is restricted to package com.big2mobile.app
# + the release SHA-1 certificate, making it safe to track.
# ⚠️  SEC-02 audit finding: keys were rotated and restricted before commit.
#     If keys are ever rotated again, update google-services.json accordingly.
# GoogleService-Info.plist (iOS) is still gitignored since it may contain more sensitive data.
GoogleService-Info.plist

# build logs (may contain sensitive data)
build.log
*.build.log
*.log
scripts/monitor-ios-builds.log

# Supabase CLI temporary files
supabase/.temp/

# generated native folders
/ios
/android

# migration scripts (one-time use only)
fix-tests.sh

credentials.json
credentials/
*.apk

# Build artifacts
*.tar.gz
*.zip

# Test outputs
test-output.log
test-results.json
