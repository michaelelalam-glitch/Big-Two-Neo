# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Bundle analysis artifacts
bundle-analysis.json

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
.env.test

# typescript
*.tsbuildinfo

# Jest transform cache (persisted in CI via actions/cache)
.jest-cache/

# E2E test results (generated by Maestro in CI)
e2e/results/

# backup files
*.bak
*.backup

# platform config (contains API keys — do NOT commit real credentials)
# google-services.json is untracked (SEC-02 audit); CI injects it from google-services.json.example.
# GoogleService-Info.plist (iOS) is also untracked for the same reason.
google-services.json
GoogleService-Info.plist

# build logs (may contain sensitive data)
build.log
*.build.log
*.log
scripts/monitor-ios-builds.log

# Supabase CLI temporary files
supabase/.temp/

# generated native folders
/ios
/android

# migration scripts (one-time use only)
fix-tests.sh

credentials.json
credentials/
*.apk

# Build artifacts
*.tar.gz
*.zip

# Test outputs
test-output.log
test-results.json
