# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Bundle analysis artifacts
bundle-analysis.json

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# Jest transform cache (persisted in CI via actions/cache)
.jest-cache/

# E2E test results (generated by Maestro in CI)
e2e/results/

# build logs (may contain sensitive data)
build.log
*.build.log
*.log
scripts/monitor-ios-builds.log

# Supabase CLI temporary files
supabase/.temp/

# generated native folders
/ios
/android

# migration scripts (one-time use only)
fix-tests.sh

# Do not commit Firebase config files; keep only local copies and/or committed *.example templates.
# If google-services.json or GoogleService-Info.plist were ever committed with real values,
# rotate the exposed Firebase credentials and purge the files from git history before any release.
google-services.json
GoogleService-Info.plist
credentials.json
credentials/
*.apk

# Backup files (use source control instead)
*.bak
*.backup
