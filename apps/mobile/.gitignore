# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Bundle analysis artifacts
bundle-analysis.json

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
.env.test

# typescript
*.tsbuildinfo

# Jest transform cache (persisted in CI via actions/cache)
.jest-cache/

# E2E test results (generated by Maestro in CI)
e2e/results/

# backup files
*.bak
*.backup

# platform config (contains API keys)
google-services.json
GoogleService-Info.plist

# build logs (may contain sensitive data)
build.log
*.build.log
*.log
scripts/monitor-ios-builds.log

# Supabase CLI temporary files
supabase/.temp/

# generated native folders
/ios
/android

# migration scripts (one-time use only)
fix-tests.sh

# SECURITY: google-services.json was previously committed and its contents are visible in
# git history and in PR diffs. The exposed Firebase credentials MUST be rotated/revoked
# and the file MUST be purged from git history (git-filter-repo / BFG Repo Cleaner) before
# any public release. Tracked as SEC-02 in docs/PRODUCTION_AUDIT_REPORT.md.
# Do not commit Firebase config files; keep only local copies and/or committed *.example templates.
google-services.json
GoogleService-Info.plist
credentials.json
credentials/
*.apk

# Build artifacts
*.tar.gz
*.zip

# Test outputs
test-output.log
test-results.json
